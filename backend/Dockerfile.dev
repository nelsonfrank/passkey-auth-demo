# Development image — installs all dependencies (including devDependencies)
# and runs the app via ts-node/watch for hot-reload.
# Used by docker-compose.override.yml automatically.

FROM node:22-alpine

WORKDIR /app

# Install pnpm
RUN npm install -g pnpm

# Copy package manifests and install all deps (no --prod flag)
COPY package.json pnpm-lock.yaml ./
RUN pnpm install

# Source is bind-mounted at runtime (see docker-compose.override.yml),
# so we don't COPY it here — this just pre-warms the layer.

EXPOSE 3000

CMD ["pnpm", "run", "start:dev"]
